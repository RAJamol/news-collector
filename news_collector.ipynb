   "source": [
    "from selenium import webdriver\n",
    "from selenium.webdriver.chrome.service import Service\n",
    "from webdriver_manager.chrome import ChromeDriverManager\n",
    "from selenium.webdriver.common.by import By\n",
    "import time"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "a7c16f9c",
   "metadata": {},
   "outputs": [],
   "source": [
    "options = webdriver.ChromeOptions()\n",
    "options.add_argument(\"--headless\")\n",
    "driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()), options=options)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "ffe6873b",
   "metadata": {},
   "outputs": [],
   "source": [
    "KEYWORDS = [\n",
    "    \"lpg shortage\",\n",
    "    \"gas shortage\",\n",
    "    \"gas supply shortage\",\n",
    "    \"cooking gas crisis\",\n",
    "    \"hotel\",\n",
    "    \"restaurant\",\n",
    "    \"eatery\",\n",
    "    \"hospitality\"\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 26,
   "id": "14491393",
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "\n",
    "def get_article_links():\n",
    "    url = \"https://news.google.com/rss/search?q=LPG+shortage+restaurant+hotel+gas+supply\"\n",
    "    \n",
    "    response = requests.get(url)\n",
    "    soup = BeautifulSoup(response.content, \"xml\")\n",
    "\n",
    "    links = []\n",
    "    for item in soup.find_all(\"item\"):\n",
    "        links.append(item.link.text)\n",
    "\n",
    "    return links"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "id": "39a958e0",
   "metadata": {},
   "outputs": [],
   "source": [
    "l=get_article_links()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "id": "1052ac48",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "100\n"
     ]
    }
   ],
   "source": [
    "print(len(l))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "d98b6f38",
   "metadata": {},
   "outputs": [],
   "source": [
    "from newspaper import Article\n",
    "\n",
    "def extract_article(url):\n",
    "    try:\n",
    "        article = Article(url)\n",
    "        article.download()\n",
    "        article.parse()\n",
    "        return article.text\n",
    "    except Exception as e:\n",
    "        print(f\"Failed: {url}\")\n",
    "        return None"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "3f3b1984",
   "metadata": {},
   "outputs": [],
   "source": [
    "def is_relevant(text):\n",
    "    text_lower = text.lower()\n",
    "    return any(keyword in text_lower for keyword in KEYWORDS)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "id": "7ee55e31",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_relevant_articles():\n",
    "    links = get_article_links()\n",
    "    results = []\n",
    "\n",
    "    for url in links:\n",
    "        driver.get(url)\n",
    "        time.sleep(1)  ,
    "\n",
    "        
    "        final_url = driver.current_url\n",
    "        print(f\"Processing: {final_url}\")\n",
    "        text = extract_article(final_url)\n",
    "\n",
    "        if text and is_relevant(text):\n",
    "            results.append({\n",
    "                \"url\": final_url,\n",
    "                \"text\": text  # preview\n",
    "            })\n",
    "\n",
    "    return results"
   ]
  },
